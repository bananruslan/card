---
import "@fontsource-variable/doto";
---

<canvas id="ticker-canvas" aria-hidden="true"></canvas>

<script>
    import { createBorderTicker } from "../lib/ticker-canvas";

    const canvas = document.getElementById(
        "ticker-canvas",
    ) as HTMLCanvasElement | null;

    if (canvas) {
        createBorderTicker(canvas);
    }
</script>

<style>
    #ticker-canvas {
        position: fixed;
        inset: 0;
        pointer-events: none;
        /* Отдельный композитный слой; без анимации transform на самом элементе */
        transform: translateZ(0);
        isolation: isolate;
        /* Ограничить распространение paint/invalidate наружу (не strict — меньше сюрпризов) */
        contain: paint;
    }
</style>
