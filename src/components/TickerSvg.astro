<svg id="border-svg" xmlns="http://www.w3.org/2000/svg">
    <defs>
        <path id="path" fill="none"></path>
    </defs>

    <!-- Группа с клип-маской для обрезки текста -->
    <g clip-path="url(#clip-path)">
        <text
            id="t-outer-1"
            font-family="Doto, sans-serif"
            font-size="12"
            font-weight="700"
            letter-spacing="3.5"
            fill="#f0ece4"
        >
            <textPath href="#path" id="text-path-1" startOffset="0%"></textPath>
        </text>

        <text
            id="t-outer-2"
            font-family="Doto, sans-serif"
            font-size="12"
            font-weight="700"
            letter-spacing="3.5"
            fill="#f0ece4"
        >
            <textPath href="#path" id="text-path-2" startOffset="0%"></textPath>
        </text>
    </g>
</svg>

<script>
    import gsap from "gsap";

    const WORDS = ["BORDER", "MARQUEE", "GSAP", "ANIMATION", "SVG", "TEXTPATH"];

    const path = document.getElementById("path");
    const clipRect = document.getElementById("clip-rect");
    const text_1 = document.getElementById("text-path-1");
    const text_2 = document.getElementById("text-path-2");

    function rrPath(
        x: number,
        y: number,
        width: number,
        height: number,
        radius: number,
    ) {
        console.log(
            `x: ${x}, y: ${y}, width: ${width}, height: ${height}, radius: ${radius}`,
        );
        return `
          M${x + radius},${y}

          L${x + width - radius},${y}
          Q${x + width},${y} ${x + width},${y + radius}

          L${x + width},${y + height - radius}
          Q${x + width},${y + height} ${x + width - radius},${y + height}

          L${x + radius},${y + height}
          Q${x},${y + height} ${x},${y + height - radius}

          L${x},${y + radius}
          Q${x},${y} ${x + radius},${y}

          Z
        `;
    }

    const PADDING = 20;
    const RADIUS = 36;

    function buildPaths() {
        const height = window.innerHeight;
        const width = window.innerWidth;

        const pathData = rrPath(
            PADDING,
            height - PADDING,
            width - PADDING * 2,
            height - PADDING * 2,
            RADIUS,
        );

        path?.setAttribute("d", pathData);
        clipRect?.setAttribute("d", pathData);
    }

    const buildText = () => {
        const height = window.innerHeight;
        const width = window.innerWidth;
        const perimeter = 2 * (height + width);

        const textContent = Array(5).fill(WORDS).flat().join(" - ");

        if (text_1 && text_2) {
            [text_1.textContent, text_2.textContent] = [
                textContent,
                textContent,
            ];

            text_1?.setAttribute("textLength", `${perimeter}px`);
            text_2?.setAttribute("textLength", `${perimeter}px`);
        }
    };

    const build = () => {
        buildPaths();
        buildText();
    };

    build();

    window.addEventListener("resize", build);

    gsap.timeline({ repeat: -1 }).from("#text-path-1", {
        attr: { startOffset: "-106%" },
        duration: 40,
        ease: "none",
        stagger: 15,
    });
    gsap.timeline({ repeat: -1 }).to("#text-path-2", {
        attr: { startOffset: "106%" },
        duration: 40,
        ease: "none",
        stagger: 15,
    });
</script>

<style>
    *,
    *::before,
    *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    :root {
        --bg: #08080e;
        --ink: #f0ece4;
        --glow: #c8f564;
        --accent: #ff4f6d;
        --mid: #6b5aff;
    }

    html,
    body {
        width: 100%;
        height: 100%;
        background: var(--bg);
        overflow: hidden;
        font-family: "Doto", sans-serif;
    }

    /* Full-page SVG */
    #border-svg {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 10;
        pointer-events: none;
        overflow: visible;
    }

    #text-path {
        position: absolute;
    }
</style>
