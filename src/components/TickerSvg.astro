<svg id="border-svg" xmlns="http://www.w3.org/2000/svg">
    <defs>
        <path id="path-outer" fill="none"></path>
        <!-- Клип-маска для эффекта overflow: hidden -->
        <!-- <clipPath id="clip-path">
            <rect id="clip-rect" fill="white" width="100" height="100"></rect>
        </clipPath> -->
    </defs>

    <!-- Группа с клип-маской для обрезки текста -->
    <g clip-path="url(#clip-path)">
        <!-- Первая лента -->
        <text
            id="t-outer-1"
            font-family="Doto, sans-serif"
            font-size="12"
            font-weight="700"
            letter-spacing="3.5"
            fill="#f0ece4"
        >
            <textPath href="#path-outer" id="tp-outer-1" startOffset="0%"
            ></textPath>
        </text>

        <!-- Вторая лента -->
        <text
            id="t-outer-2"
            font-family="Doto, sans-serif"
            font-size="12"
            font-weight="700"
            letter-spacing="3.5"
            fill="#f0ece4"
        >
            <textPath href="#path-outer" id="tp-outer-2" startOffset="0%"
            ></textPath>
        </text>
    </g>
</svg>

<script>
    import gsap from "gsap";

    const WORDS = ["BORDER", "MARQUEE", "GSAP", "ANIMATION", "SVG", "TEXTPATH"];

    const path = document.getElementById("path-outer");
    const clipRect = document.getElementById("clip-rect");
    const text1 = document.getElementById("tp-outer-1");
    const text2 = document.getElementById("tp-outer-2");

    // ── Path builder ────────────────────────────────────────────────────────
    function rrPath(
        x: number,
        y: number,
        width: number,
        height: number,
        radius: number,
    ) {
        return `M${x + radius},${y}
          L${x + width - radius},${y}
          Q${x + width},${y} ${x + width},${y + radius}

          L${x + width},${y + height - radius}
          Q${x + width},${y + height} ${x + width - radius},${y + height}

          L${x + radius},${y + height}
          Q${x},${y + height} ${x},${y + height - radius}

          L${x},${y + radius}
          Q${x},${y} ${x + radius},${y}
        Z`;
    }

    function buildPaths() {
        const PADDING = 20;
        const RADIUS = 36;

        const pathData = rrPath(
            PADDING,
            PADDING,
            window.innerWidth - PADDING * 2,
            window.innerHeight - PADDING * 2,
            RADIUS,
        );

        path?.setAttribute("d", pathData);
        // Используем тот же путь для клип-маски
        clipRect?.setAttribute("d", pathData);
    }

    const buildText = () => {
        const textContent = Array(5).fill(WORDS).flat().join(" - ");

        if (text1) text1.textContent = textContent;
        if (text2) text2.textContent = textContent;
    };

    buildPaths();
    buildText();
    window.addEventListener("resize", buildPaths);

    // ── Animation state ─────────────────────────────────────────────────────
    // const SPEED = 1;
    // const DIRECTION = 1;
    // let offset = 0;

    // gsap.ticker.add(() => {
    //     offset = (offset + SPEED * DIRECTION * 0.0016) % 100;

    //     // Первая лента
    //     text1?.setAttribute("startOffset", `${offset}%`);
    //     // Вторая лента идет сразу за первой (смещение на 50%)
    //     text2?.setAttribute("startOffset", `${(offset + 50) % 100}%`);
    // });

    gsap.timeline({ repeat: -1 }).from("#tp-outer-1", {
        attr: { startOffset: "-110%" },
        duration: 10,
        ease: "none",
        stagger: 15,
    });
    gsap.timeline({ repeat: -1 }).to("#tp-outer-2", {
        attr: { startOffset: "110%" },
        duration: 10,
        ease: "none",
        stagger: 15,
    });
</script>

<style>
    *,
    *::before,
    *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    :root {
        --bg: #08080e;
        --ink: #f0ece4;
        --glow: #c8f564;
        --accent: #ff4f6d;
        --mid: #6b5aff;
    }

    html,
    body {
        width: 100%;
        height: 100%;
        background: var(--bg);
        overflow: hidden;
        font-family: "Doto", sans-serif;
    }

    /* Full-page SVG */
    #border-svg {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 10;
        pointer-events: none;
        overflow: visible;
    }

    #tp-outer {
        position: absolute;
    }
</style>
