---
import "@fontsource-variable/bricolage-grotesque";
import Ticker from "../components/Ticker.astro";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>Ruslan Mukhutdinov</title>
    </head>
    <body>
        <div class="container">
            <slot />
        </div>
        <Ticker />
        <div class="shadow"></div>
    </body>
</html>

<style>
    html,
    body {
        background: #ff0000;
        margin: 0;
        width: 100%;
        height: 100%;
        font-family: "Bricolage Grotesque Variable";
        overscroll-behavior: none;
    }
    body {
        display: flex;
    }

    .container {
        position: relative;
        overflow: hidden;
        flex-grow: 1;
        margin: 36px;
        padding: 16px;
        border-radius: 16px;
        background-color: #fff;
    }

    .shadow {
        box-shadow: inset 0px 0px 24px rgba(0, 0, 0, 0.4);
        position: fixed;
        inset: 36px;
        pointer-events: none;
        border-radius: 16px;
    }
</style>
