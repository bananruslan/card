<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }

    .container {
        .ticker {
            font-family: "Doto", sans-serif;
            font-size: 18px;
            line-height: 36px;
            font-weight: 400;
            color: #ffffff;
            white-space: nowrap;
            align-content: center;
            position: fixed;
            height: 36px;
            background-color: #ff0000;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.25);
            overflow: hidden;
        }

        .ticker.top {
            inset: 0 0 auto;
        }

        .ticker.right {
            left: 100%;
            transform: rotate(90deg);
            transform-origin: top left;
            width: 100vh;
        }

        .ticker.bottom {
            inset: auto 0 0 0;
            box-shadow: 0 -4px 10px rgba(0, 0, 0, 0.25);
        }

        .ticker.left {
            inset: auto auto 0 36px;
            transform: rotate(-90deg);
            transform-origin: bottom left;
            width: 100vh;
        }

        .page {
            padding: 36px;
        }
    }
</style>
